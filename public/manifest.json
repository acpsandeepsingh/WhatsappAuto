{
   "action": {
      "default_icon": {
         "128": "icons/128.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "js/background.js"
   },
   "content_scripts": [ {
      "js": [ "js/inject/content-script.js", "js/load.js" ],
      "matches": [ "*://*.whatsapp.com/*" ],
      "run_at": "document_end"
   } ],
   "default_locale": "en",
   "description": "__MSG_description__",
   "host_permissions": [ "*://*.whatsapp.com/*" ],
   "icons": {
      "128": "icons/128.png"
   },
   "manifest_version": 3,
   "name": "__MSG_name__",
   "options_page": "index.html",
   "optional_host_permissions": [ "*://*/*" ],
   "permissions": [ "activeTab", "storage", "unlimitedStorage", "scripting", "alarms" ],
   "version": "1.0.0",
   "web_accessible_resources": [ {
      "matches": [ "*://*.whatsapp.com/*" ],
